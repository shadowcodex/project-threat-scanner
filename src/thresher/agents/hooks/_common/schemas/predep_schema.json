{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Thresher Pre-Dependency Discovery Agent Output",
  "description": "Schema for the JSON output produced by the predep agent",
  "type": "object",
  "required": ["hidden_dependencies", "files_scanned", "summary"],
  "properties": {
    "hidden_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "source", "found_in", "confidence", "risk"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["git", "npm", "pypi", "cargo", "go", "url", "docker", "submodule"]
          },
          "source": {
            "type": "string"
          },
          "found_in": {
            "type": "string"
          },
          "context": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "risk": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "files_scanned": {
      "type": "integer"
    },
    "summary": {
      "type": "string"
    }
  }
}
